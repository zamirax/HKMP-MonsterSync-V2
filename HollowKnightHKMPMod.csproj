<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyTitle>HollowKnightHKMPMod</AssemblyTitle>
    <AssemblyDescription>A mod that syncs mob and boss health from host to all players and gives soul to all players when any player attacks mobs</AssemblyDescription>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="HKMP" Version="2.0.0" />
    <PackageReference Include="ModdingAPI" Version="74.0.0" />
  </ItemGroup>

</Project>